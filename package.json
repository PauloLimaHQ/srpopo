{
  "name": "srpopo",
  "version": "0.1.0",
  "description": "Sr. Popo — local orchestrator hub for Claude Code tasks across your repos",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "server": "node server/index.js",
    "server:dev": "node --watch server/index.js",
    "lint": "eslint .",
    "test": "node --test",
    "dist": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "pack": "electron-builder --dir"
  },
  "keywords": [
    "claude-code",
    "claude",
    "orchestrator",
    "kanban",
    "electron",
    "developer-tools"
  ],
  "author": "Paulo Lima <pflima92@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/PauloLimaHQ/srpopo#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PauloLimaHQ/srpopo.git"
  },
  "bugs": {
    "url": "https://github.com/PauloLimaHQ/srpopo/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "type": "commonjs",
  "dependencies": {
    "express": "^4.21.2"
  },
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9.18.0",
    "globals": "^15.14.0"
  },
  "build": {
    "appId": "com.pauloperego.srpopo",
    "productName": "Sr. Popo",
    "copyright": "Copyright © 2026 Paulo",
    "asar": true,
    "files": [
      "electron/**/*",
      "server/**/*",
      "public/**/*",
      "assets/**/*",
      "build/icon.png",
      "package.json"
    ],
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "extendInfo": {
        "LSUIElement": false,
        "NSSupportsAutomaticGraphicsSwitching": true
      }
    },
    "dmg": {
      "title": "Sr. Popo ${version}"
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
